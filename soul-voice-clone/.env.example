# ElevenLabs API Key
# elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Soul Service Token
# SYS App → Verbundene Dienste → Neuer Dienst "ElevenLabs" → Token kopieren
# Empfohlene Berechtigungen: Soul ✅  Audio ✅  Bilder ✅  Kontext ✅
SOUL_SERVICE_TOKEN=

# Soul API URL
SOUL_API_URL=https://YOUR_DOMAIN/api/soul

# Soul Webhook URL (liefert Soul-Daten + Audio-URLs)
SOUL_WEBHOOK_URL=https://YOUR_DOMAIN/api/webhook/elevenlabs

# Twilio – für Phase 2/3 (whatsapp-soul.mjs, whatsapp-connect.mjs)
# console.twilio.com → Account → API Keys & Tokens
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=

# Meta WhatsApp – für Phase 3 (whatsapp-connect.mjs)
# developers.facebook.com → App → WhatsApp → API-Setup
META_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
# business.facebook.com → System Users → Token generieren (permanent)
META_PERMANENT_TOKEN=
