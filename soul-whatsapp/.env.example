# Twilio Serverless – WhatsApp Soul Agent
# Deploy: twilio serverless:deploy --override-existing-project

# Twilio credentials
# console.twilio.com → Account → API Keys & Tokens
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp sender number (Twilio Sandbox or approved Business number)
# console.twilio.com → Messaging → Try it out → Send a WhatsApp message
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SYS API – connect to your own SaveYourSoul instance
# Format: https://YOUR_DOMAIN/api/soul
SOUL_API_URL=https://YOUR_DOMAIN/api/soul

# Webhook URL for ElevenLabs voice agent replies
# Format: https://YOUR_DOMAIN/api/webhook/elevenlabs
SOUL_WEBHOOK_URL=https://YOUR_DOMAIN/api/webhook/elevenlabs

# Service Token (soul-specific)
# SYS App → Verbundene Dienste → Neuer Dienst → Token kopieren
# Recommended permissions: Soul ✅  Audio ✅  Context ✅
SOUL_SERVICE_TOKEN=

# Anthropic API Key
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
