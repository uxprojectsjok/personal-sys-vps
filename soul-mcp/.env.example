# soul-mcp – Umgebungsvariablen
# Kopiere diese Datei als .env und fülle die Werte aus

# Port des MCP-Servers (wird hinter OpenResty proxied)
PORT=3098

# Öffentliche URL des Servers (wird in OAuth-Metadaten verwendet)
BASE_URL=https://YOUR_DOMAIN

# SaveYourSoul API-Basis-URL
SYS_API_URL=https://YOUR_DOMAIN

# Polygon-Netzwerk: "amoy" (Testnet) oder "main" (Mainnet)
POLYGON_NETWORK=amoy

# OAuth – Client-Secrets (optional, für spätere Multi-Client-Unterstützung)
# Claude.ai registriert sich als Public Client (kein Secret nötig)
# OAUTH_CLIENT_SECRET=
