# ── Server-Secrets (nur für nuxt dev – nie im Static-Build) ─────────────────
# In Production werden diese Keys in der OpenResty systemd-Override gesetzt.

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Master-Key für HMAC-Zertifikatsvalidierung
# soul_cert = HMAC-SHA256(SOUL_MASTER_KEY, soul_id).slice(0, 32)
# Muss auf lokaler Maschine UND auf dem VPS (systemd override) identisch sein.
# Generieren: openssl rand -hex 32
SOUL_MASTER_KEY=change-me-generate-with-openssl-rand-hex-32

# Signing-Key für Session-Log-Signaturen (optional, separater Key)
API_SIGNING_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Public-Vars (werden bei "npm run generate" in den Build eingebacken) ────
# Diese Werte sind im Browser sichtbar – keine Secrets!

# WalletConnect / Reown AppKit Project ID
# Projekt anlegen: cloud.reown.com → Create Project → Web3 Apps
# Erlaubte Origins eintragen: https://yourdomain.com + http://localhost:3007
WALLETCONNECT_PROJECT_ID=

# Spotify Integration (optional)
# App anlegen: developer.spotify.com → Dashboard → App
# Redirect URI: https://yourdomain.com/session + http://localhost:3007/session
SPOTIFY_CLIENT_ID=

# YouTube / Google Integration (optional)
# console.cloud.google.com → APIs & Dienste → YouTube Data API v3 aktivieren
# OAuth 2.0 Client-ID (Webanwendung) → Redirect URI: https://yourdomain.com/session
YOUTUBE_CLIENT_ID=
